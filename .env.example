# Copy this file to `.env` inside WSL and edit paths/Forge identity if your local install differs.
DECKBUILDER_DATABASE_URL=postgresql+psycopg://deckbuilder:deckbuilder@localhost:5432/deckbuilder
DECKBUILDER_LOG_LEVEL=INFO
DECKBUILDER_LLM_DISABLED=true

DECKBUILDER_FORGE_ROOT=~/.local/forge
DECKBUILDER_FORGE_DECKS_DIR=~/.forge/decks/commander
DECKBUILDER_FORGE_BUNDLED_DECK_DIR=~/.local/forge/res/adventure/Realm of Legends/decks/legends
DECKBUILDER_FORGE_AI_PROFILE=forge-daily-snapshot
DECKBUILDER_FORGE_BUILD_ID=2.0.13-SNAPSHOT-06.11-2026-06-11T19:12:03Z
DECKBUILDER_DEFAULT_SEED=42
